# Copy this file to .env and fill values before running the app

# Supabase service URL (example: https://xyzcompany.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key with admin privileges (keep secret)
SUPABASE_SERVICE_ROLE_KEY=service_role_key_here

# Google OAuth2 credentials (create OAuth Client ID in Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: override redirect URI (if running behind a proxy / on Render)
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/auth/callback

# Encryption & session secrets (use long random values)
APP_TOKEN_ENCRYPTION_KEY=replace-with-long-random-string
APP_SESSION_SECRET=replace-with-long-random-string

# When true, cookies will be set with Secure; set to false for local HTTP dev
COOKIE_SECURE=true

# Poller interval override (seconds)
#POLL_INTERVAL_SECONDS=10
